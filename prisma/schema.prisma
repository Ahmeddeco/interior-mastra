generator zod {
  provider                         = "zod-prisma-types"
  output                           = "../src/generated/zod"
  useMultipleFiles                 = true
  writeNullishInModelTypes         = true
  createModelTypes                 = true
  writeBarrelFiles                 = false
  createInputTypes                 = false
  addInputTypeValidation           = false
  addIncludeType                   = false
  addSelectType                    = false
  validateWhereUniqueInput         = false
  createOptionalDefaultValuesTypes = false
  createRelationValuesTypes        = false
  createPartialTypes               = false
  useDefaultValidators             = false
  coerceDate                       = false
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model User {
  id            String     @id @default(cuid())
  name          String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  email         String     @unique
  emailVerified Boolean    @default(false)
  image         String?
  sessions      Session[]
  accounts      Account[]
  role          Role       @default(user)
  lat           String?
  lng           String?
  mobile        String?    @unique
  city          String?
  state         String?
  country       String?
  favorites     Favorite[]
  factories     Factory[]
  designs       Design[]
  articles      Article[]

  @@unique([email, mobile])
  @@index([email])
  @@index([name])
  @@map("user")
}

model Factory {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logo      String?
  info      String?   @db.Text
  country   String
  state     String
  city      String?
  mobile    String
  hotLine   String?
  owner     User[]
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([slug])
  @@index([name])
}

model Style {
  id            String    @id @default(cuid())
  titleAr       String    @unique
  titleEn       String    @unique
  slug          String    @unique
  descriptionAr String?   @db.Text
  descriptionEn String?   @db.Text
  image         String?
  product       Product[]
  designs       Design[]

  @@index([slug])
}

model Color {
  id        String    @id @default(cuid())
  titleAr   String    @unique
  titleEn   String    @unique
  slug      String    @unique
  colorCode String    @unique
  product   Product[]

  @@index([slug])
}

model Class {
  id            String    @id @default(cuid())
  titleAr       String    @unique
  titleEn       String    @unique
  slug          String    @unique
  image         String?
  descriptionAr String?   @db.Text
  descriptionEn String?   @db.Text
  product       Product[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([slug])
}

model Favorite {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId, productId])
}

enum Role {
  admin
  user
  manufacturer
  client
  designer
}

enum ProductStatus {
  draft
  published
  archived
}

model Product {
  id                String        @id @default(cuid())
  titleAr           String
  titleEn           String
  miniDescriptionAr String
  miniDescriptionEn String
  descriptionAr     String?       @db.Text
  descriptionEn     String?       @db.Text
  slug              String        @unique
  model             String        @unique
  status            ProductStatus @default(draft)
  quantity          Int           @default(0)
  lowStock          Int           @default(0)
  price             Int           @default(0)
  discount          Int?          @default(0)
  mainImage         String
  images            String[]
  color             Color[]
  favorites         Favorite[]
  factory           Factory       @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  factoryId         String
  style             Style         @relation(fields: [styleId], references: [id], onDelete: Cascade)
  styleId           String
  class             Class         @relation(fields: [classId], references: [id])
  classId           String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([factoryId])
  @@index([classId])
  @@index([styleId])
  @@index([price])
  @@index([slug])
}

model Design {
  id            String   @id @default(cuid())
  titleAr       String
  titleEn       String
  slug          String   @unique
  descriptionAr String?  @db.Text
  descriptionEn String?  @db.Text
  painPointsAr  String?  @db.Text
  painPointsEn  String?  @db.Text
  solutionsAr   String?  @db.Text
  solutionsEn   String?  @db.Text
  mainImage     String
  images        String[]
  country       String?
  state         String?
  city          String?
  client        User     @relation(fields: [userId], references: [id])
  style         Style    @relation(fields: [styleId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String
  styleId       String

  @@index([userId])
  @@index([styleId])
  @@index([slug])
  @@index([titleAr])
  @@index([titleEn])
}

model Article {
  id            String   @id @default(cuid())
  author        User     @relation(fields: [userId], references: [id])
  titleAr       String
  titleEn       String
  descriptionAr String
  descriptionEn String
  slug          String   @unique
  topicAr       String   @db.Text
  topicEn       String   @db.Text
  mainImage     String
  images        String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String

  @@index([titleAr])
  @@index([titleEn])
  @@index([slug])
  @@index([userId])
}
